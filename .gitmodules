	url = https://github.com/supportersimulator/3-surgeons.git
	branch = main

[submodule "engines/multi-fleet"]
	path = engines/multi-fleet
	url = https://github.com/supportersimulator/multi-fleet.git
	branch = main

# ============================================================
# TODO: confirm public URL — may be private
