# public (or private-but-accessible) GitHub repo, or swap this URL
# for the internal mirror. wire-submodules.sh will log this to
# submodule-todo.md and skip if unreachable — it will NOT fail.
# ============================================================
[submodule "engines/context-dna"]
	path = engines/context-dna
	url = https://github.com/supportersimulator/context-dna.git
	branch = main

