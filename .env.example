# ContextDNA IDE — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# === LLM Providers ===
# Primary provider routing (choose one of: openai, deepseek, anthropic, deepseek-first-openai-fallback)
LLM_EXTERNAL_PROVIDER=deepseek-first-openai-fallback

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Local LLM (MLX/Ollama) — used by P4 background tasks
LOCAL_LLM_URL=http://127.0.0.1:5044
LOCAL_LLM_MODEL=

# === NATS (Fleet Coordination) ===
NATS_URL=nats://localhost:4222
MULTIFLEET_NODE_ID=local

# === Webhook / Health Daemon ===
WEBHOOK_HEALTH_PORT=8855
WEBHOOK_S2_TIMEOUT_S=30
WEBHOOK_S6_TIMEOUT_S=20

# === Storage ===
CONTEXTDNA_DATA_DIR=$HOME/.contextdna
EVIDENCE_DB_PATH=$HOME/.contextdna/evidence.db

# === Optional: 3-Surgeons Multi-Model Consensus ===
SURGEON_CARDIO_PROVIDER=deepseek
SURGEON_NEURO_PROVIDER=deepseek
SURGEON_COST_CAP_USD=0.05

# === Optional: User identity for hooks ===
USER_EMAIL=you@example.com
