# =============================================================================
# ContextDNA IDE — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in real values for your machine.
# Never commit `.env` — only `.env.example` is tracked.
#
# Two profiles ship with the mothership:
#   - lite   (laptop, 2-3 GB RAM): only the "Core" + "Local LLM" sections
#            are strictly required.
#   - heavy  (Mac Studio / server / cloud, 6+ GB RAM): all sections apply.
#
# Bidirectional sync (NATS leaf-node) is optional but recommended whenever
# you run more than one mothership node.
# =============================================================================


# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------

# Postgres role used by the evidence ledger and session memory.
POSTGRES_USER=contextdna

# Postgres password. Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=YOUR_KEY_HERE

# Postgres database name — keep `contextdna` unless you have a reason.
POSTGRES_DB=contextdna

# Redis password for hot-path pub/sub and per-machine session cache.
REDIS_PASSWORD=YOUR_KEY_HERE

# NATS URL the mothership uses to reach the local fleet daemon.
# In lite mode this is the local container; in heavy mode this is the chief.
NATS_URL=nats://127.0.0.1:4222

# Stable identifier for this mothership instance across the fleet roster.
# Use short, machine-friendly names: `mac1`, `mac3`, `cloud`, `cabin-laptop`.
MULTIFLEET_NODE_ID=YOUR_NODE_ID_HERE


# -----------------------------------------------------------------------------
# LLM providers (at least one required)
# -----------------------------------------------------------------------------
# The mothership picks the cheapest / most-local provider that has a key.
# Configure as many or as few as you want.

# OpenAI API key — used for GPT-4.1 / GPT-4o powerhouse calls and OSS fallback.
OPENAI_API_KEY=YOUR_KEY_HERE

# Anthropic API key — used for Claude / Claude Code powerhouse calls.
ANTHROPIC_API_KEY=YOUR_KEY_HERE

# DeepSeek API key — primary external provider for P1/P2 fallback (cheapest
# capable Claude-class model in the priority queue).
DEEPSEEK_API_KEY=YOUR_KEY_HERE

# Alternative DeepSeek key slot — picked up by the Atlas LLM priority queue
# when a separate budget envelope is required for the subconscious.
Context_DNA_Deep_Seek=YOUR_KEY_HERE


# -----------------------------------------------------------------------------
# Local LLM (lite mode default)
# -----------------------------------------------------------------------------
# The local subconscious. On Apple Silicon, MLX is the default. On Linux,
# the mothership falls back to Ollama (see HEAVY-only section below).

# MLX model id (Hugging Face hub path). Default is small and fast.
MLX_MODEL=mlx-community/Qwen3-4B-4bit

# Local MLX server port. The mothership talks to it via host.docker.internal.
MLX_PORT=5044


# -----------------------------------------------------------------------------
# Heavy-only (skip in lite mode)
# -----------------------------------------------------------------------------
# These services only boot in `docker-compose.heavy.yml`.

# RabbitMQ admin user for Celery worker queues.
RABBITMQ_USER=contextdna

# RabbitMQ password. Generate with: openssl rand -base64 32
RABBITMQ_PASSWORD=YOUR_KEY_HERE

# S3-compatible (SeaweedFS) access key — used for SOPs, evidence blobs, artifacts.
S3_ACCESS_KEY=contextdna

# S3-compatible secret key. Generate with: openssl rand -base64 32
S3_SECRET_KEY=YOUR_KEY_HERE

# Grafana admin user.
GRAFANA_USER=admin

# Grafana admin password. Generate with: openssl rand -base64 32
GRAFANA_PASSWORD=YOUR_KEY_HERE


# -----------------------------------------------------------------------------
# Sync (bidirectional heavy + lite)
# -----------------------------------------------------------------------------
# Lite nodes attach to a heavy node via a NATS leaf-node link so the evidence
# ledger replicates fleet-wide. Leave blank to run standalone (no sync).

# Remote NATS URL the leaf-node should dial. Typically `nats://chief.example:7422`.
NATS_LEAF_REMOTE_URL=YOUR_KEY_HERE

# Username on the remote NATS chief (configured in heavy node's leaf.conf).
NATS_LEAF_USER=YOUR_KEY_HERE

# Password on the remote NATS chief. Generate with: openssl rand -base64 32
NATS_LEAF_PASSWORD=YOUR_KEY_HERE


# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# None of these are required for the mothership to boot. Each unlocks one
# panel or notification surface.

# Discord webhook URL — used by the fleet daemon for human-visible alerts.
DISCORD_WEBHOOK_URL=YOUR_KEY_HERE

# Stripe live secret key (revenue panel + checkout flows).
STRIPE_SECRET_KEY=YOUR_KEY_HERE

# Stripe webhook signing secret (verifies Stripe -> mothership events).
STRIPE_WEBHOOK_SECRET=YOUR_KEY_HERE

# Stripe publishable key (used by panels rendering checkout in the browser).
STRIPE_PUBLISHABLE_KEY=YOUR_KEY_HERE

# Superset base URL when the analytics panel is wired up.
SUPERSET_URL=YOUR_KEY_HERE

# Superset service account username.
SUPERSET_USERNAME=YOUR_KEY_HERE

# Superset service account password.
SUPERSET_PASSWORD=YOUR_KEY_HERE

# Bidirectional sync target (lite → heavy NATS leaf-node endpoint)
NATS_REMOTE_URL=nats://127.0.0.1:4222
