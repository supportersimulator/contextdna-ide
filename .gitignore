# =============================================================================
# ContextDNA IDE — Mothership .gitignore
# =============================================================================
# Conservative by default. Personal state, secrets, and runtime artifacts
# stay local; the open-source skeleton (specs, scripts, code) tracks cleanly.
# =============================================================================


# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Build artifacts
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
sdist/
wheels/
share/python-wheels/
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# Test + type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
.venv*/
venv/
venv*/
ENV/
env/


# ----------------------------------------------------------------------------
# Node / TypeScript / Frontend panels
# ----------------------------------------------------------------------------
node_modules/
.npm
.yarn-integrity
*.tsbuildinfo
.next/
out/
dist/
.parcel-cache/
.turbo/

# Submodule node_modules — engines and apps each carry their own.
engines/*/node_modules/
apps/*/node_modules/


# ----------------------------------------------------------------------------
# Docker / runtime volumes
# ----------------------------------------------------------------------------
.docker-volumes/
docker-volumes/


# ----------------------------------------------------------------------------
# Secrets — these MUST NEVER be committed.
# ----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
.env.*.local
# But keep the template:
!.env.example

*.key
*.pem
*.crt
*.p12

# Service-specific token caches
.openai_token
.anthropic_token
.deepseek_token


# ----------------------------------------------------------------------------
# Runtime databases + logs
# ----------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-journal
*.log
logs/
tmp/
/tmp/


# ----------------------------------------------------------------------------
# Personal / private mothership state
# ----------------------------------------------------------------------------
# Family wisdom and personal corpora are never open-sourced.
memory/family_wisdom/
memory/*.db
memory/*.sqlite
memory/*.db-shm
memory/*.db-wal
memory/.*.json
memory/.work_log_archives/

# Per-machine session state files — generated at runtime, machine-specific.
.ab_testing_log.json
.active_session_injections.json
.agent_service_heartbeat.json
.agent_service_startup.lock
.auto_capture_state.json
.brain_cache.json
.context_ab_tracking.db
.ecosystem_health_stderr.log
.ecosystem_health_stdout.log
.evidence_ledger_append_counters.json
.evidence_ledger_redact_counters.json
.failure_patterns.db
.governance_kill_switch.json
.heartbeat_config.json
.hindsight_validator.db
.hindsight_validator.db-shm
.hindsight_validator.db-wal
.session_index.db

# Fleet runtime artifacts
.fleet-messages/
submissions/
artifacts/
dashboard_exports/


# ----------------------------------------------------------------------------
# NATS / JetStream local data
# ----------------------------------------------------------------------------
nats-server.pid
jetstream/


# ----------------------------------------------------------------------------
# Large binary models — never tracked.
# ----------------------------------------------------------------------------
*.bin
*.weights
*.gguf
*.onnx
*.safetensors


# ----------------------------------------------------------------------------
# IDE / editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
.claude/
.cursor/
*.swp
*.swo
*~


# ----------------------------------------------------------------------------
# OS
# ----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
Thumbs.db
ehthumbs.db
Desktop.ini
