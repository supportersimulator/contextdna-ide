    echo ""
}

print_header() {
    echo ""
    echo -e "${CYAN}══════════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  $1${NC}"
    echo -e "${CYAN}══════════════════════════════════════════════════════════════════════${NC}"
    echo ""
}

print_step() {
    echo -e "${BLUE}▶ $1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

print_info() {
    echo -e "${MAGENTA}ℹ️  $1${NC}"
}

# =============================================================================
# Retry and Fallback Functions (Guaranteed Installation)
# =============================================================================

# Retry a command up to N times with exponential backoff
# Usage: retry_command 3 "pip install mlx"
retry_command() {
    local max_attempts="${1:-3}"
    local delay=2
    local attempt=1
    shift
    local cmd="$@"

    while [ $attempt -le $max_attempts ]; do
        if eval "$cmd"; then
            return 0
        fi

        if [ $attempt -lt $max_attempts ]; then
            print_warning "Attempt $attempt failed, retrying in ${delay}s... ($(($max_attempts - $attempt)) attempts left)"
            sleep $delay
            delay=$((delay * 2))  # Exponential backoff
        fi
        attempt=$((attempt + 1))
    done

    print_error "Command failed after $max_attempts attempts: $cmd"
    return 1
}

# Install pip packages with retries
# Usage: pip_install_retry "$PYTHON" "package1 package2"
pip_install_retry() {
    local python="$1"
    local packages="$2"
    local max_attempts=3
    local attempt=1

    while [ $attempt -le $max_attempts ]; do
        if "$python" -m pip install $packages -q 2>/dev/null; then
            return 0
        fi

        # If quiet mode failed, try verbose to see error
        if [ $attempt -eq $max_attempts ]; then
            print_warning "Attempting verbose install to diagnose..."
            "$python" -m pip install $packages
        else
            print_warning "pip install attempt $attempt failed, retrying..."
            sleep 2
        fi
        attempt=$((attempt + 1))
    done

    return 1
}

# Install brew package with retries and fallback versions
# Usage: brew_install_retry "$BREW" "python@3.12" "python@3.11 python@3.10"
brew_install_retry() {
    local brew="$1"
    local package="$2"
    local fallbacks="${3:-}"

    # Try primary package
    if retry_command 2 "$brew install $package"; then
        return 0
    fi

    # Try fallbacks
    for fallback in $fallbacks; do
        print_warning "Trying fallback: $fallback"
        if retry_command 2 "$brew install $fallback"; then
            print_success "Installed fallback: $fallback"
            return 0
        fi
    done

    return 1
}

# Wait for service with timeout and retries
# Usage: wait_for_service "http://127.0.0.1:5043/health" 30
wait_for_service() {
    local url="$1"
    local timeout="${2:-30}"
    local interval="${3:-1}"
    local elapsed=0

    while [ $elapsed -lt $timeout ]; do
        if curl -s "$url" &>/dev/null; then
            return 0
        fi
        sleep $interval
        elapsed=$((elapsed + interval))
    done

    return 1
}

prompt_yes_no() {
    local prompt="$1"
    local default="${2:-y}"
    local response

    if [ "$default" = "y" ]; then
        echo -en "${YELLOW}$prompt [Y/n]: ${NC}"
    else
        echo -en "${YELLOW}$prompt [y/N]: ${NC}"
    fi

    read -r response
    response=${response:-$default}

    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

wait_for_enter() {
    echo -en "${YELLOW}Press Enter to continue...${NC}"
    read -r
}

# =============================================================================
# Prerequisite Checks
# =============================================================================

check_python() {
    print_step "Checking Python 3..."

    if command -v python3 &> /dev/null; then
        PYTHON_VERSION=$(python3 --version 2>&1 | grep -oE '[0-9]+\.[0-9]+')
        PYTHON_MAJOR=$(echo "$PYTHON_VERSION" | cut -d. -f1)
        PYTHON_MINOR=$(echo "$PYTHON_VERSION" | cut -d. -f2)

        if [ "$PYTHON_MAJOR" -ge 3 ] && [ "$PYTHON_MINOR" -ge 8 ]; then
            print_success "Python $PYTHON_VERSION found"
            return 0
        else
            print_warning "Python $PYTHON_VERSION found but 3.8+ required"
        fi
    fi

    print_error "Python 3.8+ is required but not found"
    echo ""

    if [ "$OS_TYPE" = "Darwin" ]; then
        echo "Install Python on macOS:"
        echo "  Option 1: brew install python@3.12"
        echo "  Option 2: Download from https://www.python.org/downloads/"
    else
        echo "Install Python on Linux:"
        echo "  Ubuntu/Debian: sudo apt install python3 python3-venv python3-pip"
        echo "  Fedora: sudo dnf install python3 python3-pip"
    fi
    echo ""

    if prompt_yes_no "Would you like me to try installing Python automatically?"; then
        install_python
        return $?
    fi

    return 1
}

install_python() {
    if [ "$OS_TYPE" = "Darwin" ]; then
        if command -v brew &> /dev/null; then
            print_step "Installing Python via Homebrew..."
            brew install python@3.12
            print_success "Python installed"
            return 0
        else
            print_error "Homebrew not found. Please install Python manually."
            return 1
        fi
    else
        print_error "Automatic Python installation not supported on this OS"
        return 1
    fi
}

check_homebrew() {
    if [ "$OS_TYPE" != "Darwin" ]; then
        return 0  # Skip on non-macOS
    fi

    print_step "Checking Homebrew (macOS package manager)..."

    if command -v brew &> /dev/null; then
        print_success "Homebrew found"
        return 0
    fi

    print_warning "Homebrew not found (needed for xbar installation)"

    if prompt_yes_no "Would you like to install Homebrew?"; then
        print_step "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

        # Add Homebrew to PATH for this session
        if [ -f "/opt/homebrew/bin/brew" ]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        fi

        print_success "Homebrew installed"
        return 0
    fi

    return 1
}

# =============================================================================
# ARM64 Homebrew + MLX Setup (Apple Silicon Native)
# =============================================================================

setup_arm64_homebrew_and_mlx() {
    if [ "$OS_TYPE" != "Darwin" ]; then
        return 0  # Skip on non-macOS
    fi

    ARCH=$(uname -m)
    if [ "$ARCH" != "arm64" ]; then
        print_info "Not Apple Silicon - skipping ARM64 setup"
        return 0
    fi

    print_header "Apple Silicon Native Setup (ARM64 Homebrew + MLX)"

    echo "For optimal MLX performance, Context DNA needs:"
    echo "  • ARM64 Homebrew (in /opt/homebrew)"
    echo "  • Native ARM64 Python 3.12"
    echo "  • MLX framework for Metal GPU acceleration"
    echo ""

    # Check if ARM64 Homebrew exists
    if [ -f "/opt/homebrew/bin/brew" ]; then
        print_success "ARM64 Homebrew found at /opt/homebrew"
        ARM_BREW="/opt/homebrew/bin/brew"
    else
        # Check if Intel Homebrew is being used
        if [ -f "/usr/local/bin/brew" ]; then
            print_warning "Intel Homebrew detected at /usr/local/bin"
            print_info "MLX requires ARM64 Homebrew for native Metal GPU access"
            echo ""
        fi

        if ! prompt_yes_no "Install ARM64 Homebrew for native Metal GPU performance?"; then
            print_info "Skipping ARM64 Homebrew - will use Ollama instead"
            return 0
        fi

        # Request sudo upfront for directory creation
        echo ""
        echo -e "${YELLOW}${BOLD}Administrator password required to install ARM64 Homebrew${NC}"
        echo "This creates /opt/homebrew for native Apple Silicon tools."
        echo ""

        # Try standard sudo first, fall back to GUI prompt if no TTY
        if sudo -v 2>/dev/null; then
            # TTY available - sudo works normally
            print_success "Administrator access confirmed"
            USE_ASKPASS=false
        else
            # No TTY available - use macOS GUI password prompt with SUDO_ASKPASS
            print_step "Requesting administrator access via system dialog..."

            # Get password via GUI dialog (only asked ONCE)
            SUDO_PASS=$(osascript -e 'display dialog "Context DNA needs administrator access to install ARM64 Homebrew for native Metal GPU acceleration.\n\nEnter your password:" default answer "" with hidden answer with title "Context DNA Installer" with icon caution' -e 'text returned of result' 2>/dev/null)

            if [ -z "$SUDO_PASS" ]; then
                print_error "Password dialog cancelled"
                print_info "Install manually: arch -arm64 /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
                return 1
            fi

            # Validate the password works
            if ! echo "$SUDO_PASS" | sudo -S -v 2>/dev/null; then
                print_error "Invalid password"
                print_info "Install manually: arch -arm64 /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
                unset SUDO_PASS
                return 1
            fi

            # Create a temporary askpass script that provides the password
            # This allows ALL sudo calls (including Homebrew's internal ones) to work
            ASKPASS_SCRIPT=$(mktemp)
            chmod 700 "$ASKPASS_SCRIPT"
            cat > "$ASKPASS_SCRIPT" << ASKPASS_EOF
#!/bin/bash
echo '$SUDO_PASS'
ASKPASS_EOF

            # Export SUDO_ASKPASS so all sudo calls use it
            export SUDO_ASKPASS="$ASKPASS_SCRIPT"
            USE_ASKPASS=true

            # Clear password from memory (it's now in the askpass script)
            unset SUDO_PASS

            print_success "Administrator access configured (password entered once)"
        fi

        # Keep sudo credential cache alive during installation
        (while true; do sudo -n true 2>/dev/null || true; sleep 50; done) &
        SUDO_KEEPALIVE_PID=$!

        print_step "Creating /opt/homebrew directories..."
        # Create ALL directories Homebrew needs
        BREW_DIRS="/opt/homebrew /opt/homebrew/bin /opt/homebrew/etc /opt/homebrew/include /opt/homebrew/lib /opt/homebrew/sbin /opt/homebrew/share /opt/homebrew/var /opt/homebrew/opt /opt/homebrew/share/zsh /opt/homebrew/share/zsh/site-functions /opt/homebrew/var/homebrew /opt/homebrew/var/homebrew/linked /opt/homebrew/Cellar /opt/homebrew/Caskroom /opt/homebrew/Frameworks /opt/homebrew/share/doc /opt/homebrew/share/man /opt/homebrew/share/man/man1"

        if [ "$USE_ASKPASS" = true ]; then
            # Use -A flag which tells sudo to use SUDO_ASKPASS
            sudo -A mkdir -p $BREW_DIRS
            sudo -A chown -R $(whoami):admin /opt/homebrew
            sudo -A chmod -R 755 /opt/homebrew
            echo "/opt/homebrew/bin" | sudo -A tee /etc/paths.d/homebrew > /dev/null
        else
            sudo mkdir -p $BREW_DIRS
            sudo chown -R $(whoami):admin /opt/homebrew
            sudo chmod -R 755 /opt/homebrew
            echo "/opt/homebrew/bin" | sudo tee /etc/paths.d/homebrew > /dev/null
        fi

        print_step "Installing ARM64 Homebrew..."
        # CI=1 NONINTERACTIVE=1 tells Homebrew to run non-interactively
        # SUDO_ASKPASS is already exported, so Homebrew's sudo calls will use it
        CI=1 NONINTERACTIVE=1 arch -arm64 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

        # Cleanup: kill keepalive and remove askpass script
        kill $SUDO_KEEPALIVE_PID 2>/dev/null || true
        if [ "$USE_ASKPASS" = true ] && [ -n "$ASKPASS_SCRIPT" ]; then
            rm -f "$ASKPASS_SCRIPT"
            unset SUDO_ASKPASS
        fi

        if [ -f "/opt/homebrew/bin/brew" ]; then
            print_success "ARM64 Homebrew installed"
            ARM_BREW="/opt/homebrew/bin/brew"
            # Add to PATH for this session
            eval "$(/opt/homebrew/bin/brew shellenv)"
        else
            print_error "ARM64 Homebrew installation failed"
            return 1
        fi
    fi

    # Check for ARM64 Python - try 3.12 first, fallback to 3.11, 3.10
    print_step "Checking for ARM64 Python..."

    ARM_PYTHON=""

    # Check existing Python versions (prefer 3.12 > 3.11 > 3.10)
    for pyver in python3.12 python3.11 python3.10; do
        PYPATH="/opt/homebrew/bin/$pyver"
        if [ -f "$PYPATH" ]; then
            PYTHON_ARCH=$(file "$PYPATH" 2>/dev/null | grep -o 'arm64' || echo "")
            if [ "$PYTHON_ARCH" = "arm64" ]; then
                print_success "ARM64 $pyver found"
                ARM_PYTHON="$PYPATH"
                break
            fi
        fi
    done

    # Install if not found
    if [ -z "$ARM_PYTHON" ]; then
        print_step "Installing ARM64 Python (with fallbacks)..."

        # Try Python 3.12, fall back to 3.11, then 3.10
        if brew_install_retry "$ARM_BREW" "python@3.12" "python@3.11 python@3.10"; then
            # Find which version was installed
            for pyver in python3.12 python3.11 python3.10; do
                PYPATH="/opt/homebrew/bin/$pyver"
                if [ -f "$PYPATH" ]; then
                    ARM_PYTHON="$PYPATH"
                    print_success "Installed $pyver"
                    break
                fi
            done
        fi
    fi

    if [ -z "$ARM_PYTHON" ] || [ ! -f "$ARM_PYTHON" ]; then
        print_error "Failed to install ARM64 Python"
        print_info "Try manually: /opt/homebrew/bin/brew install python@3.12"
        return 1
    fi

    # Create ARM64 venv for MLX
    MLX_VENV_DIR="$CONTEXT_DNA_DIR/venv-mlx"

    if [ -d "$MLX_VENV_DIR" ]; then
        # Check if existing venv is ARM64 and working
        if "$MLX_VENV_DIR/bin/python3" -c "import platform; exit(0 if platform.machine() == 'arm64' else 1)" 2>/dev/null; then
            print_success "ARM64 MLX venv already exists"
        else
            print_warning "Existing venv is broken or not ARM64 - recreating"
            rm -rf "$MLX_VENV_DIR"
            if ! "$ARM_PYTHON" -m venv "$MLX_VENV_DIR"; then
                print_error "Failed to create venv"
                return 1
            fi
        fi
    else
        print_step "Creating ARM64 virtual environment for MLX..."
        if ! "$ARM_PYTHON" -m venv "$MLX_VENV_DIR"; then
            print_error "Failed to create venv"
            return 1
        fi
        print_success "ARM64 venv created at $MLX_VENV_DIR"
    fi

    # Upgrade pip with retry
    print_step "Upgrading pip..."
    retry_command 3 "'$MLX_VENV_DIR/bin/pip' install --upgrade pip -q"

    # Install MLX with retry (this is the critical package)
    print_step "Installing MLX framework (with retries)..."
    if ! pip_install_retry "$MLX_VENV_DIR/bin/python3" "mlx mlx-lm"; then
        print_error "Failed to install MLX"
        print_info "Try manually: $MLX_VENV_DIR/bin/pip install mlx mlx-lm"
        return 1
    fi
    print_success "MLX installed"

    # Install all server dependencies with retry
    print_step "Installing Local LLM server dependencies (with retries)..."
    SERVER_DEPS="fastapi uvicorn httpx pyyaml rich platformdirs keyring cryptography pydantic"
    if ! pip_install_retry "$MLX_VENV_DIR/bin/python3" "$SERVER_DEPS"; then
        print_warning "Some dependencies failed, trying individually..."
        # Try each package individually
        for pkg in $SERVER_DEPS; do
            if ! pip_install_retry "$MLX_VENV_DIR/bin/python3" "$pkg"; then
                print_warning "Failed to install $pkg (may be optional)"
            fi
        done
    fi
    print_success "Server dependencies installed"

    # Verify MLX installation
    if "$MLX_VENV_DIR/bin/python3" -c "import mlx.core as mx; print('MLX version:', getattr(mx, '__version__', 'unknown')); assert mx.metal.is_available(), 'Metal not available'" 2>/dev/null; then
        print_success "MLX installed and Metal GPU is available!"

        # Export for later use
        export MLX_PYTHON="$MLX_VENV_DIR/bin/python3"
        export MLX_VENV_DIR="$MLX_VENV_DIR"

        # Create symlink for easy access
        ln -sf "$MLX_VENV_DIR/bin/python3" "$CONTEXT_DNA_DIR/mlx-python"
        print_info "MLX Python available at: $CONTEXT_DNA_DIR/mlx-python"

        echo ""
        echo -e "${GREEN}${BOLD}✓ ARM64 Native Setup Complete${NC}"
        echo "  • ARM64 Homebrew: /opt/homebrew/bin/brew"
        echo "  • ARM64 Python: $ARM_PYTHON"
        echo "  • MLX venv: $MLX_VENV_DIR"
        echo "  • Metal GPU: Enabled"
        echo ""

        return 0
    else
        print_error "MLX installation failed or Metal not available"
        print_info "Check: $MLX_VENV_DIR/bin/python3 -c 'import mlx.core as mx; print(mx.metal.is_available())'"
        return 1
    fi
}

# =============================================================================
# Optional Dependencies
# =============================================================================

check_and_install_xbar() {
    if [ "$OS_TYPE" != "Darwin" ]; then
        print_info "xbar is only available on macOS (skipping)"
        return 0
    fi

    print_header "xbar - Menu Bar Integration"

    echo "xbar displays Context DNA stats in your macOS menu bar:"
    echo "  • Active A/B tests and sample counts"
    echo "  • Hook performance rates"
    echo "  • Pattern evolution status"
    echo "  • Quick access to management commands"
    echo ""

    # Check if xbar is installed
    if [ -d "/Applications/xbar.app" ] || [ -d "$HOME/Applications/xbar.app" ]; then
        print_success "xbar is already installed"
        setup_xbar_plugin
        return 0
    fi

    if ! prompt_yes_no "Would you like to install xbar for menu bar stats?"; then
        print_info "Skipping xbar installation"
        return 0
    fi

    if ! command -v brew &> /dev/null; then
        print_warning "Homebrew not found - cannot install xbar automatically"
        echo "Install manually from: https://xbarapp.com/"
        return 1
    fi

    print_step "Installing xbar via Homebrew..."
    brew install --cask xbar

    if [ -d "/Applications/xbar.app" ]; then
        print_success "xbar installed successfully"

        # Launch xbar
        if prompt_yes_no "Would you like to launch xbar now?"; then
            open "/Applications/xbar.app"
            echo ""
            print_info "xbar is starting. You'll see it in your menu bar."
            sleep 2
        fi

        setup_xbar_plugin
    else
        print_error "xbar installation may have failed"
        return 1
    fi

    return 0
}

setup_xbar_plugin() {
    print_step "Setting up Context DNA xbar plugin..."

    XBAR_PLUGINS_DIR="$HOME/Library/Application Support/xbar/plugins"

    # Create plugins directory if needed
    mkdir -p "$XBAR_PLUGINS_DIR"

    # Create the xbar plugin script
    PLUGIN_FILE="$XBAR_PLUGINS_DIR/context-dna.5m.sh"

    cat > "$PLUGIN_FILE" << 'XBAR_PLUGIN'
#!/bin/bash
# <xbar.title>Context DNA Stats</xbar.title>
# <xbar.version>v1.0</xbar.version>
# <xbar.author>Context DNA</xbar.author>
# <xbar.desc>Shows Context DNA learning system stats</xbar.desc>
# <xbar.var>string(CONTEXT_DNA_REPO=""): Path to Context DNA repo</xbar.var>

# Configuration
REPO_DIR="${CONTEXT_DNA_REPO:-$HOME/dev/er-simulator-superrepo}"
PYTHON="${CONTEXT_DNA_PYTHON:-$REPO_DIR/.venv/bin/python3}"
XBAR_SCRIPT="$REPO_DIR/context-dna/core/src/context_dna/xbar_hook_stats.py"

# Fallback to memory location (legacy)
if [ ! -f "$XBAR_SCRIPT" ]; then
    XBAR_SCRIPT="$REPO_DIR/memory/xbar_hook_stats.py"
fi

# Check if script exists
if [ ! -f "$XBAR_SCRIPT" ]; then
    echo "🧬 ?"
    echo "---"
    echo "Context DNA not configured"
    echo "Run install script | bash='$REPO_DIR/scripts/install-context-dna.sh'"
    exit 0
fi

# Get stats
STATS=$("$PYTHON" "$XBAR_SCRIPT" --xbar 2>/dev/null)

if [ -z "$STATS" ]; then
    echo "🧬 ⚠️"
    echo "---"
    echo "Error getting stats"
    exit 0
fi

# Parse stats
TESTS=$(echo "$STATS" | grep "^TESTS:" | cut -d: -f2)
SAMPLES=$(echo "$STATS" | grep "^SAMPLES:" | cut -d: -f2)
AVGRATE=$(echo "$STATS" | grep "^AVGRATE:" | cut -d: -f2)
PATTERNS=$(echo "$STATS" | grep "^PATTERNS:" | cut -d: -f2)
WISDOM=$(echo "$STATS" | grep "^WISDOM:" | cut -d: -f2)
CONTEXTS=$(echo "$STATS" | grep "^CONTEXTS:" | cut -d: -f2)

# Menu bar title
if [ "$TESTS" -gt 0 ]; then
    echo "🧬 ${TESTS}T ${SAMPLES}S ${AVGRATE}%"
else
    echo "🧬 ${PATTERNS}P"
fi

echo "---"
echo "Context DNA Stats | size=14"
echo "---"
echo "🧪 Active Tests: $TESTS"
echo "📊 Total Samples: $SAMPLES"
echo "📈 Avg Success Rate: ${AVGRATE}%"
echo "---"
echo "📚 Active Patterns: $PATTERNS"
echo "💡 Wisdom Injections: $WISDOM"
echo "🎯 Contexts Learned: $CONTEXTS"
echo "---"

# Variants section
VARIANTS=$(echo "$STATS" | grep "^VARIANT:")
if [ -n "$VARIANTS" ]; then
    echo "Hook Variants | size=12"
    echo "$VARIANTS" | while IFS='|' read -r line; do
        name=$(echo "$line" | cut -d: -f2 | cut -d'|' -f1)
        group=$(echo "$line" | cut -d'|' -f2)
        samples=$(echo "$line" | cut -d'|' -f3)
        rate=$(echo "$line" | cut -d'|' -f4)
        echo "  $name ($group): ${samples}s ${rate}%"
    done
    echo "---"
fi

# Actions
echo "Open Menu | bash='$PYTHON' param1='$REPO_DIR/context-dna/core/src/context_dna/hook_manager.py' param2='menu' terminal=true"
echo "Refresh | refresh=true"
XBAR_PLUGIN

    chmod +x "$PLUGIN_FILE"

    print_success "xbar plugin installed at $PLUGIN_FILE"
    print_info "The plugin refreshes every 5 minutes automatically"
}

check_and_install_vscode() {
    print_header "VS Code - Recommended IDE"

    echo "VS Code with Claude Code extension provides:"
    echo "  • Integrated AI coding assistant"
    echo "  • Automatic context injection from Context DNA"
    echo "  • Hook triggers on every prompt"
    echo ""

    # Check if VS Code is installed
    if command -v code &> /dev/null; then
        print_success "VS Code is already installed"
        check_claude_code_extension
        return 0
    fi

    # Check common installation paths
    if [ -d "/Applications/Visual Studio Code.app" ] || \
       [ -d "$HOME/Applications/Visual Studio Code.app" ] || \
       [ -d "/usr/share/code" ]; then
        print_success "VS Code found"
        check_claude_code_extension
        return 0
    fi

    if ! prompt_yes_no "Would you like to install VS Code?"; then
        print_info "Skipping VS Code installation"
        print_warning "Note: Context DNA works best with VS Code + Claude Code extension"
        return 0
    fi

    if [ "$OS_TYPE" = "Darwin" ]; then
        if command -v brew &> /dev/null; then
            print_step "Installing VS Code via Homebrew..."
            brew install --cask visual-studio-code
            print_success "VS Code installed"
        else
            echo ""
            echo "Please download VS Code from: https://code.visualstudio.com/download"
            wait_for_enter
        fi
    else
        echo ""
        echo "Please download VS Code from: https://code.visualstudio.com/download"
        wait_for_enter
    fi

    check_claude_code_extension
    return 0
}

check_claude_code_extension() {
    print_step "Checking Claude Code extension..."

    # Check if 'code' command is available
    if ! command -v code &> /dev/null; then
        # Try to add VS Code to PATH on macOS
        if [ "$OS_TYPE" = "Darwin" ] && [ -d "/Applications/Visual Studio Code.app" ]; then
            print_info "Adding VS Code to PATH..."
            export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
        fi
    fi

    if command -v code &> /dev/null; then
        # Check if Claude Code extension is installed
        if code --list-extensions 2>/dev/null | grep -qi "anthropic\|claude"; then
            print_success "Claude Code extension is installed"
            return 0
        fi

        print_warning "Claude Code extension not found"

        if prompt_yes_no "Would you like to install the Claude Code extension?"; then
            print_step "Installing Claude Code extension..."

            # Try different extension IDs (the actual ID may vary)
            if code --install-extension anthropics.claude-code 2>/dev/null; then
                print_success "Claude Code extension installed"
            elif code --install-extension anthropic.claude-code 2>/dev/null; then
                print_success "Claude Code extension installed"
            else
                print_warning "Could not install automatically"
                echo ""
                echo "To install manually:"
                echo "  1. Open VS Code"
                echo "  2. Press Cmd+Shift+X (or Ctrl+Shift+X)"
                echo "  3. Search for 'Claude Code'"
                echo "  4. Click Install"
                echo ""
                wait_for_enter
            fi
        fi
    else
        print_info "VS Code 'code' command not available"
        echo ""
        echo "To install Claude Code extension manually:"
        echo "  1. Open VS Code"
        echo "  2. Press Cmd+Shift+X (Extensions)"
        echo "  3. Search for 'Claude Code'"
        echo "  4. Click Install"
        echo ""
    fi

    return 0
}

# =============================================================================
# Core Installation Steps
# =============================================================================

create_directories() {
    print_step "Creating Context DNA directories..."

    mkdir -p "$CONTEXT_DNA_DIR"
    mkdir -p "$CONTEXT_DNA_DIR/sessions"
    mkdir -p "$CONTEXT_DNA_DIR/backups"
    mkdir -p "$CONTEXT_DNA_DIR/cache"

    print_success "Created $CONTEXT_DNA_DIR"
}

setup_venv() {
    print_step "Setting up Python virtual environment..."

    if [ ! -d "$VENV_DIR" ]; then
        python3 -m venv "$VENV_DIR"
        print_success "Created virtual environment at $VENV_DIR"
    else
        print_success "Virtual environment already exists"
    fi

    # Activate and install dependencies
    source "$VENV_DIR/bin/activate"

    print_step "Installing Python dependencies..."
    pip install --quiet --upgrade pip

    # Install core dependencies
    pip install --quiet rich pyyaml requests

    # Install Context DNA package in development mode (now at context-dna/core/)
    if [ -f "$REPO_DIR/context-dna/core/pyproject.toml" ]; then
        print_step "Installing Context DNA package..."
        pip install --quiet -e "$REPO_DIR/context-dna/core"
        print_success "Context DNA package installed"
    fi

    # Try to install acontext SDK (may not be available publicly)
    if pip install --quiet acontext 2>/dev/null; then
        print_success "Installed Context DNA SDK (acontext)"
    else
        print_info "Context DNA SDK not available - using local mode"
    fi

    print_success "Python dependencies installed"
}

