run_hierarchy_analysis() {
    print_step "Analyzing your codebase structure..."

    # First, detect platform
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${BOLD}🔍 Platform Detection${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Use hardware.py for platform detection (single source of truth)
    PLATFORM_INFO=$("$VENV_DIR/bin/python3" -c "
import sys
sys.path.insert(0, '$REPO_DIR/context-dna')
try:
    from local_llm.hardware import get_recommended_setup
    setup = get_recommended_setup()
    p = setup['profile']
    print(f'OS: {p.os}')
    print(f'Arch: {p.arch}')
    print(f'RAM: {p.ram_gb}GB')
    if p.chip_name:
        print(f'Chip: {p.chip_name}')
    if p.is_apple_silicon:
        print(f'Apple Silicon: Yes')
    if p.is_rosetta:
        print(f'Rosetta 2: Running under emulation')
    print(f'Recommended Backend: {setup[\"backend\"]}')
    print(f'Recommended Model: {setup[\"model_name\"]}')
except Exception as e:
    print(f'Platform detection fallback: {e}')
" 2>/dev/null || echo "Platform: $OS_TYPE ($(uname -m))")

    echo "$PLATFORM_INFO"
    echo ""

    # Now analyze codebase hierarchy
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${BOLD}🏗️  Codebase Structure Analysis${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Use HierarchyAnalyzer if available
    HIERARCHY_RESULT=$("$VENV_DIR/bin/python3" -c "
import sys
sys.path.insert(0, '$REPO_DIR/context-dna/src')
sys.path.insert(0, '$REPO_DIR/context-dna')
try:
    from context_dna.setup.hierarchy_analyzer import HierarchyAnalyzer
    analyzer = HierarchyAnalyzer('$REPO_DIR')
    profile = analyzer.analyze()

    print(f'Repository Type: {profile.repo_type.value}')
    print(f'')
    print(f'Detected Services:')
    for cat, loc in profile.locations.items():
        framework = f' ({loc.framework})' if loc.framework else ''
        print(f'  • {cat}: {loc.path}{framework}')

    if profile.submodules:
        print(f'')
        print(f'Git Submodules:')
        for sub in profile.submodules:
            print(f'  • {sub.path}')

    # Save profile to file for later use
    import json
    from pathlib import Path
    profile_path = Path('$CONTEXT_DNA_DIR') / 'hierarchy_profile.json'
    profile_path.parent.mkdir(parents=True, exist_ok=True)
    profile_path.write_text(profile.to_json())
    print(f'')
    print(f'✓ Profile saved to: {profile_path}')

except ImportError as e:
    print(f'HierarchyAnalyzer not available yet: {e}')
    print('Will use basic detection during installation.')
except Exception as e:
    print(f'Analysis error: {e}')
    print('Continuing with default configuration.')
" 2>/dev/null || echo "Codebase analysis will run after core installation")

    echo "$HIERARCHY_RESULT"
    echo ""

    # Show what we'll do based on profile
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${BOLD}📋 Installation Plan${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Check if profile exists and show placement plan
    if [ -f "$CONTEXT_DNA_DIR/hierarchy_profile.json" ]; then
        PLACEMENT_PLAN=$("$VENV_DIR/bin/python3" -c "
import sys
sys.path.insert(0, '$REPO_DIR/context-dna/src')
try:
    from context_dna.setup.placement_engine import PlacementEngine
    from context_dna.setup.models import HierarchyProfile
    from pathlib import Path
    import json

    profile_data = json.loads(Path('$CONTEXT_DNA_DIR/hierarchy_profile.json').read_text())
    profile = HierarchyProfile.from_dict(profile_data)

    engine = PlacementEngine(profile)

    # Get suggestions for key components
    components = ['local_llm_client', 'celery_tasks', 'hooks_config']
    for comp in components:
        try:
            suggestion = engine.suggest_placement(comp)
            if suggestion:
                print(f'  • {comp}: {suggestion.action} → {suggestion.path}')
        except:
            pass
except Exception as e:
    pass
" 2>/dev/null)

        if [ -n "$PLACEMENT_PLAN" ]; then
            echo "Based on your codebase structure:"
            echo "$PLACEMENT_PLAN"
        else
            echo "Using default installation paths"
        fi
    else
        echo "Using default installation paths"
    fi

    echo ""
    print_success "Hierarchy analysis complete"
}

# =============================================================================
# Local LLM Backend Installation
# =============================================================================

install_llm_backend() {
    print_header "Local LLM Backend"

    echo "Context DNA can use a local LLM for intelligent features:"
    echo "  • Smart context injection"
    echo "  • Pattern analysis"
    echo "  • Code understanding"
    echo ""

    # Detect architecture and show appropriate info
    ARCH=$(uname -m)
    if [ "$OS_TYPE" = "Darwin" ] && [ "$ARCH" = "arm64" ]; then
        echo -e "${GREEN}${BOLD}Apple Silicon Detected!${NC}"
        echo ""
        echo "Your system will use ${CYAN}MLX${NC} - Apple's native ML framework:"
        echo "  • Direct Metal GPU acceleration"
        echo "  • Optimized for M1/M2/M3/M4/M5 chips"
        echo "  • No Docker or external services needed"
        echo "  • Models run at native speed on your GPU"
        echo ""
    else
        echo "Your system will use ${CYAN}Ollama${NC} - cross-platform LLM runtime:"
        echo "  • Works on Intel Macs, Linux, Windows"
        echo "  • Easy model management"
        echo "  • Wide model compatibility"
        echo ""
    fi

    if ! prompt_yes_no "Would you like to install and start the local LLM backend?"; then
        print_info "Skipping local LLM backend installation"
        print_warning "You can install it later with: python -m context_dna.local_llm.mlx_installer"
        return 0
    fi

    # Determine which Python/venv to use
    MLX_VENV_DIR="$CONTEXT_DNA_DIR/venv-mlx"

    if [ "$OS_TYPE" = "Darwin" ] && [ "$ARCH" = "arm64" ] && [ -d "$MLX_VENV_DIR" ]; then
        # Apple Silicon: Use MLX venv (already set up in Phase 1)
        LLM_PYTHON="$MLX_VENV_DIR/bin/python3"
        print_step "Using MLX venv for Local LLM server..."

        # Verify MLX is installed (with retry if needed)
        if ! "$LLM_PYTHON" -c "import mlx" 2>/dev/null; then
            print_step "Installing MLX in venv (with retries)..."
            retry_command 3 "'$LLM_PYTHON' -m pip install --upgrade pip -q"
            if ! pip_install_retry "$LLM_PYTHON" "mlx mlx-lm"; then
                print_error "Failed to install MLX after retries"
                return 1
            fi
        fi

        # Ensure all server dependencies are installed (with retries)
        print_step "Verifying Local LLM server dependencies..."
        SERVER_DEPS="fastapi uvicorn httpx pyyaml rich platformdirs keyring cryptography pydantic"
        pip_install_retry "$LLM_PYTHON" "$SERVER_DEPS" || true  # Non-fatal if some fail

        print_success "MLX backend ready"

    else
        # Non-Apple Silicon: Use Ollama
        print_step "Setting up Ollama backend..."

        if command -v ollama &> /dev/null; then
            print_success "Ollama already installed"
        elif curl -s "http://127.0.0.1:11434/api/tags" &>/dev/null; then
            print_success "Ollama service running"
        else
            if [ "$OS_TYPE" = "Darwin" ]; then
                if command -v brew &> /dev/null; then
                    print_step "Installing Ollama via Homebrew (with retries)..."
                    if retry_command 3 "brew install ollama"; then
                        print_success "Ollama installed"
                    else
                        print_warning "Failed to install Ollama"
                        print_info "Install manually from: https://ollama.ai"
                    fi
                else
                    print_warning "Install Ollama from: https://ollama.ai"
                fi
            else
                print_warning "Install Ollama from: https://ollama.ai"
            fi
        fi

        # Use main venv for Ollama backend
        LLM_PYTHON="$VENV_DIR/bin/python3"

        # Install server dependencies in main venv (with retries)
        print_step "Installing Local LLM server dependencies..."
        SERVER_DEPS="fastapi uvicorn httpx pyyaml rich platformdirs keyring cryptography pydantic"
        pip_install_retry "$LLM_PYTHON" "$SERVER_DEPS" || true

        print_success "Ollama backend ready"
    fi

    # Start the Local LLM server (with retries)
    start_llm_server "$LLM_PYTHON"

    return 0
}

# =============================================================================
# Start Local LLM Server
# =============================================================================

start_llm_server() {
    local LLM_PYTHON="${1:-$CONTEXT_DNA_DIR/venv-mlx/bin/python3}"
    local SERVER_SCRIPT="$REPO_DIR/context-dna/local_llm/start_server.py"
    local LOG_FILE="$CONTEXT_DNA_DIR/local-llm.log"
    local PID_FILE="$CONTEXT_DNA_DIR/local-llm.pid"
    local MAX_RETRIES=3
    local retry=1

    print_step "Starting Local LLM server (with retries)..."

    while [ $retry -le $MAX_RETRIES ]; do
        # Stop any existing server
        if [ -f "$PID_FILE" ]; then
            OLD_PID=$(cat "$PID_FILE" 2>/dev/null)
            if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
                print_info "Stopping existing server (PID: $OLD_PID)..."
                kill "$OLD_PID" 2>/dev/null || true
                sleep 1
            fi
            rm -f "$PID_FILE"
        fi

        # Also kill any orphaned servers
        pkill -f "start_server.py" 2>/dev/null || true
        pkill -f "uvicorn.*api_server" 2>/dev/null || true
        sleep 1

        # Verify the server script exists
        if [ ! -f "$SERVER_SCRIPT" ]; then
            print_error "Server script not found: $SERVER_SCRIPT"
            return 1
        fi

        # Verify Python works
        if ! "$LLM_PYTHON" -c "print('ok')" &>/dev/null; then
            print_error "Python interpreter not working: $LLM_PYTHON"
            return 1
        fi

        # Start the server in background
        print_info "Starting server attempt $retry/$MAX_RETRIES..."
        nohup "$LLM_PYTHON" "$SERVER_SCRIPT" > "$LOG_FILE" 2>&1 &
        SERVER_PID=$!
        echo "$SERVER_PID" > "$PID_FILE"

        # Wait for server to be ready (up to 15 seconds)
        if wait_for_service "http://127.0.0.1:5043/health" 15; then
            print_success "Local LLM server is running!"
            echo ""
            echo -e "${GREEN}  Server URL: http://127.0.0.1:5043${NC}"
            echo -e "${GREEN}  Health:     http://127.0.0.1:5043/health${NC}"
            echo -e "${GREEN}  API Docs:   http://127.0.0.1:5043/docs${NC}"
            echo -e "${GREEN}  Log file:   $LOG_FILE${NC}"
            echo ""

            # Create a convenience script to manage the server
            create_server_management_script "$LLM_PYTHON"

            return 0
        fi

        # Check if process died
        if ! kill -0 "$SERVER_PID" 2>/dev/null; then
            print_warning "Server process died on attempt $retry"
            if [ $retry -lt $MAX_RETRIES ]; then
                print_info "Checking logs for error..."
                tail -10 "$LOG_FILE" 2>/dev/null || true
                sleep 2
            fi
        else
            print_warning "Server running but not responding on attempt $retry"
        fi

        retry=$((retry + 1))
    done

    # All retries failed - show comprehensive diagnostics
    print_error "Server failed to start after $MAX_RETRIES attempts"
    echo ""
    print_info "=== Diagnostics ==="
    echo "Python: $LLM_PYTHON"
    echo "Script: $SERVER_SCRIPT"
    echo ""
    print_info "=== Last 30 lines of log ==="
    tail -30 "$LOG_FILE" 2>/dev/null || echo "(no log file)"
    echo ""
    print_info "=== Manual start command ==="
    echo "$LLM_PYTHON $SERVER_SCRIPT"
    echo ""
    print_info "Full log: $LOG_FILE"

    return 1
}

create_server_management_script() {
    local LLM_PYTHON="$1"
    local SCRIPT_PATH="$CONTEXT_DNA_DIR/local-llm"

    cat > "$SCRIPT_PATH" << SERVER_SCRIPT
#!/bin/bash
# Context DNA Local LLM Server Management
# Usage: local-llm [start|stop|status|restart|logs]

PYTHON="$LLM_PYTHON"
SERVER="$REPO_DIR/context-dna/local_llm/start_server.py"
LOG="$CONTEXT_DNA_DIR/local-llm.log"
PID_FILE="$CONTEXT_DNA_DIR/local-llm.pid"

case "\${1:-status}" in
    start)
        if curl -s "http://127.0.0.1:5043/health" &>/dev/null; then
            echo "Server already running"
            exit 0
        fi
        pkill -f "start_server.py" 2>/dev/null || true
        nohup "\$PYTHON" "\$SERVER" > "\$LOG" 2>&1 &
        echo \$! > "\$PID_FILE"
        sleep 2
        if curl -s "http://127.0.0.1:5043/health" &>/dev/null; then
            echo "Server started: http://127.0.0.1:5043"
        else
            echo "Failed to start. Check: \$LOG"
        fi
        ;;
    stop)
        pkill -f "start_server.py" 2>/dev/null || true
        rm -f "\$PID_FILE"
        echo "Server stopped"
        ;;
    restart)
        "\$0" stop
        sleep 1
        "\$0" start
        ;;
    status)
        if curl -s "http://127.0.0.1:5043/health" &>/dev/null; then
            echo "Server running: http://127.0.0.1:5043"
            curl -s "http://127.0.0.1:5043/health"
            echo ""
        else
            echo "Server not running"
        fi
        ;;
    logs)
        tail -f "\$LOG"
        ;;
    *)
        echo "Usage: local-llm [start|stop|status|restart|logs]"
        ;;
esac
SERVER_SCRIPT

    chmod +x "$SCRIPT_PATH"
    print_info "Server management: $SCRIPT_PATH [start|stop|status|restart|logs]"
}

migrate_databases() {
    print_step "Migrating databases to centralized location..."

    # Check for existing databases in memory/
    MEMORY_DIR="$REPO_DIR/memory"

    if [ -f "$MEMORY_DIR/.pattern_evolution.db" ] && [ ! -L "$MEMORY_DIR/.pattern_evolution.db" ]; then
        cp "$MEMORY_DIR/.pattern_evolution.db" "$CONTEXT_DNA_DIR/.pattern_evolution.db"
        # Create symlink for backwards compatibility
        rm "$MEMORY_DIR/.pattern_evolution.db"
        ln -sf "$CONTEXT_DNA_DIR/.pattern_evolution.db" "$MEMORY_DIR/.pattern_evolution.db"
        print_success "Migrated .pattern_evolution.db"
    elif [ -L "$MEMORY_DIR/.pattern_evolution.db" ]; then
        print_success ".pattern_evolution.db already migrated (symlink exists)"
    fi

    if [ -f "$MEMORY_DIR/.pattern_registry.db" ] && [ ! -L "$MEMORY_DIR/.pattern_registry.db" ]; then
        cp "$MEMORY_DIR/.pattern_registry.db" "$CONTEXT_DNA_DIR/.pattern_registry.db"
        rm "$MEMORY_DIR/.pattern_registry.db"
        ln -sf "$CONTEXT_DNA_DIR/.pattern_registry.db" "$MEMORY_DIR/.pattern_registry.db"
        print_success "Migrated .pattern_registry.db"
    elif [ -L "$MEMORY_DIR/.pattern_registry.db" ]; then
        print_success ".pattern_registry.db already migrated (symlink exists)"
    fi
}

configure_hooks() {
    print_step "Configuring Claude Code hooks..."

    CLAUDE_CONFIG_DIR="$HOME/.claude"
    HOOKS_FILE="$CLAUDE_CONFIG_DIR/settings.json"

    # Create Claude config directory if needed
    mkdir -p "$CLAUDE_CONFIG_DIR"

    # Check if hooks are already configured
    if [ -f "$HOOKS_FILE" ]; then
        if grep -q "auto-memory-query.sh" "$HOOKS_FILE" 2>/dev/null; then
            print_success "Claude Code hooks already configured"
            return
        fi

        # Backup existing config
        cp "$HOOKS_FILE" "$HOOKS_FILE.backup.$(date +%Y%m%d_%H%M%S)"
        print_info "Backed up existing settings.json"
    fi

    # Create or update settings.json
    cat > "$HOOKS_FILE" << EOF
{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/scripts/auto-memory-query.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/scripts/auto-capture-results.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/scripts/auto-session-summary.sh"
          }
        ]
      }
    ]
  }
}
EOF

    print_success "Claude Code hooks configured in $HOOKS_FILE"
}

setup_environment() {
    print_step "Setting up environment variables..."

    # Create environment file
    ENV_FILE="$CONTEXT_DNA_DIR/.env"

    if [ ! -f "$ENV_FILE" ]; then
        cat > "$ENV_FILE" << EOF
# Context DNA Configuration
# Generated by install-context-dna.sh on $(date)

# Repository location
CONTEXT_DNA_REPO=$REPO_DIR

# User data directory
CONTEXT_DNA_DIR=$CONTEXT_DNA_DIR

# Python interpreter
CONTEXT_DNA_PYTHON=$VENV_DIR/bin/python3

# API Configuration (update these if using remote Context DNA server)
CONTEXT_DNA_BASE_URL=http://localhost:8029/api/v1
CONTEXT_DNA_API_KEY=sk-ac-your-root-api-bearer-token
EOF
        print_success "Created environment file at $ENV_FILE"
    else
        print_success "Environment file already exists"
    fi

    # Add to shell profile if not already there
    SHELL_PROFILE=""
    if [ -f "$HOME/.zshrc" ]; then
        SHELL_PROFILE="$HOME/.zshrc"
    elif [ -f "$HOME/.bashrc" ]; then
        SHELL_PROFILE="$HOME/.bashrc"
    fi

    if [ -n "$SHELL_PROFILE" ]; then
        if ! grep -q "CONTEXT_DNA" "$SHELL_PROFILE" 2>/dev/null; then
            echo "" >> "$SHELL_PROFILE"
            echo "# Context DNA" >> "$SHELL_PROFILE"
            echo "export CONTEXT_DNA_REPO=\"$REPO_DIR\"" >> "$SHELL_PROFILE"
            echo "export CONTEXT_DNA_DIR=\"$CONTEXT_DNA_DIR\"" >> "$SHELL_PROFILE"
            echo "export CONTEXT_DNA_PYTHON=\"$VENV_DIR/bin/python3\"" >> "$SHELL_PROFILE"
            print_success "Added environment variables to $SHELL_PROFILE"
        else
            print_success "Environment variables already in shell profile"
        fi
    fi
}

verify_installation() {
    print_step "Verifying installation..."

    ERRORS=0
    WARNINGS=0

    echo ""

    # Check directories
    if [ -d "$CONTEXT_DNA_DIR" ]; then
        print_success "Context DNA directory exists"
    else
        print_error "Context DNA directory missing"
        ERRORS=$((ERRORS + 1))
    fi

    # Check Python
    if [ -f "$VENV_DIR/bin/python3" ]; then
        print_success "Python virtual environment exists"
    else
        print_error "Python virtual environment missing"
        ERRORS=$((ERRORS + 1))
    fi

    # Test imports
    if "$VENV_DIR/bin/python3" -c "from context_dna.hook_evolution import HookEvolutionEngine" 2>/dev/null; then
        print_success "Context DNA package imports successfully"
    elif "$VENV_DIR/bin/python3" -c "from memory.hook_evolution import get_hook_evolution_engine" 2>/dev/null; then
        print_success "Hook Evolution engine imports (via memory/)"
    else
        print_error "Hook Evolution engine import failed"
        ERRORS=$((ERRORS + 1))
    fi

    if "$VENV_DIR/bin/python3" -c "from memory.brain import ArchitectureBrain" 2>/dev/null; then
        print_success "Architecture Brain imports successfully"
    else
        print_warning "Architecture Brain import failed"
        WARNINGS=$((WARNINGS + 1))
    fi

    # Check hooks configuration
    if [ -f "$HOME/.claude/settings.json" ]; then
        if grep -q "auto-memory-query.sh" "$HOME/.claude/settings.json" 2>/dev/null; then
            print_success "Claude Code hooks configured"
        else
            print_warning "Claude Code hooks not fully configured"
            WARNINGS=$((WARNINGS + 1))
        fi
    else
        print_warning "Claude Code settings.json not found"
        WARNINGS=$((WARNINGS + 1))
    fi

    # Check optional components
    echo ""
    echo "Optional Components:"

    # xbar
    if [ "$OS_TYPE" = "Darwin" ]; then
        if [ -d "/Applications/xbar.app" ] || [ -d "$HOME/Applications/xbar.app" ]; then
            print_success "xbar installed"
        else
            print_info "xbar not installed (optional)"
        fi
    fi

    # VS Code
    if command -v code &> /dev/null || [ -d "/Applications/Visual Studio Code.app" ]; then
        print_success "VS Code installed"

        # Claude Code extension
        if command -v code &> /dev/null && code --list-extensions 2>/dev/null | grep -qi "claude\|anthropic"; then
            print_success "Claude Code extension installed"
        else
            print_info "Claude Code extension not detected"
        fi
    else
        print_info "VS Code not installed (optional)"
    fi

    # Local LLM Backend
    echo ""
    echo "Local LLM Backend:"

    # Check if Local LLM server is running
    if curl -s "http://127.0.0.1:5043/health" &>/dev/null; then
        print_success "Local LLM server running at http://127.0.0.1:5043"
    else
        print_info "Local LLM server not running"
        if [ -f "$CONTEXT_DNA_DIR/local-llm" ]; then
            print_info "Start with: $CONTEXT_DNA_DIR/local-llm start"
        fi
    fi

    # Check for MLX (Apple Silicon)
    MLX_VENV_DIR="$CONTEXT_DNA_DIR/venv-mlx"
    if [ "$OS_TYPE" = "Darwin" ]; then
        ARCH=$(uname -m)
        if [ "$ARCH" = "arm64" ]; then
            if [ -f "$MLX_VENV_DIR/bin/python3" ] && "$MLX_VENV_DIR/bin/python3" -c "import mlx.core as mx; exit(0 if mx.metal.is_available() else 1)" 2>/dev/null; then
                print_success "MLX backend installed with Metal GPU"
            elif [ -f "$MLX_VENV_DIR/bin/python3" ] && "$MLX_VENV_DIR/bin/python3" -c "import mlx" 2>/dev/null; then
                print_warning "MLX installed but Metal not available"
            else
                print_info "MLX not installed (recommended for Apple Silicon)"
            fi
        fi
    fi

    # Check for Ollama
    if command -v ollama &> /dev/null; then
        print_success "Ollama backend available"
    elif curl -s "http://127.0.0.1:11434/api/tags" &>/dev/null; then
        print_success "Ollama API responding"
    else
        if [ "$OS_TYPE" != "Darwin" ] || [ "$(uname -m)" != "arm64" ]; then
            print_info "Ollama not detected (recommended for this system)"
        fi
    fi

    echo ""
    if [ $ERRORS -eq 0 ]; then
        if [ $WARNINGS -eq 0 ]; then
            print_success "Installation verified successfully! All systems go."
        else
            print_success "Installation verified with $WARNINGS warnings"
        fi
    else
        print_error "$ERRORS verification checks failed"
    fi

    return $ERRORS
}

show_usage() {
    echo "Context DNA Installation Wizard"
    echo ""
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --quick         Skip optional dependencies (xbar, VS Code prompts)"
    echo "  --hooks-only    Only configure Claude Code hooks"
    echo "  --verify        Only verify existing installation"
    echo "  --help          Show this help message"
    echo ""
    echo "Environment Variables:"
    echo "  CONTEXT_DNA_DIR    User data directory (default: ~/.context-dna)"
    echo "  CONTEXT_DNA_REPO   Repository path (auto-detected)"
    echo ""
}

show_final_instructions() {
    print_header "Installation Complete!"

    echo -e "${GREEN}Context DNA is now installed and ready to use.${NC}"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo -e "${BOLD}Quick Start:${NC}"
    echo ""
    echo "  1. Restart your terminal (or run: source ~/.zshrc)"
    echo ""
    echo "  2. Open VS Code in this repository:"
    echo "     code $REPO_DIR"
    echo ""
    echo "  3. Start Claude Code (Cmd+Shift+P → 'Claude: Open')"
    echo ""
    echo "  4. Context DNA will automatically inject wisdom on every prompt!"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo -e "${BOLD}Management Commands:${NC}"
    echo ""
    echo "  # Open the interactive menu"
    echo "  $VENV_DIR/bin/python3 -m context_dna.hook_manager menu"
    echo ""
    echo "  # Query memory for a topic"
    echo "  $VENV_DIR/bin/python3 memory/query.py 'docker deployment'"
    echo ""
    echo "  # Ask the Professor for guidance"
    echo "  $VENV_DIR/bin/python3 memory/professor.py 'deploy to production'"
    echo ""
    echo "  # Record a success"
    echo "  $VENV_DIR/bin/python3 memory/brain.py success 'task' 'what worked'"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Show LLM backend status
    echo -e "${BOLD}Local LLM Backend:${NC}"
    if [ "$OS_TYPE" = "Darwin" ] && [ "$(uname -m)" = "arm64" ]; then
        if "$VENV_DIR/bin/python3" -c "import mlx" 2>/dev/null; then
            echo "  MLX backend installed (native Metal acceleration)"
            echo "  Download a model: python -c \"from mlx_lm import load; load('mlx-community/Qwen2.5-Coder-7B-Instruct-4bit')\""
        else
            echo "  MLX not installed. Install with:"
            echo "  $VENV_DIR/bin/python3 $REPO_DIR/context-dna/local_llm/mlx_installer.py"
        fi
    else
        if command -v ollama &> /dev/null; then
            echo "  Ollama backend available"
            echo "  Pull a model: ollama pull qwen2.5-coder:7b"
        else
            echo "  Install Ollama from https://ollama.ai"
        fi
    fi
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    if [ "$OS_TYPE" = "Darwin" ] && [ -d "/Applications/xbar.app" ]; then
        echo -e "${BOLD}Menu Bar:${NC}"
        echo "  xbar shows Context DNA stats in your menu bar (🧬)"
        echo ""
    fi

    echo -e "${MAGENTA}Documentation: $REPO_DIR/context-dna/README.md${NC}"
    echo ""
}

# =============================================================================
# Main
# =============================================================================

main() {
    # Parse arguments
    QUICK_MODE=false
    HOOKS_ONLY=false
    VERIFY_ONLY=false

    for arg in "$@"; do
        case $arg in
            --quick)
                QUICK_MODE=true
                ;;
            --hooks-only)
                HOOKS_ONLY=true
                ;;
            --verify)
                VERIFY_ONLY=true
                ;;
            --help|-h)
                show_usage
                exit 0
                ;;
        esac
    done

    print_banner

    echo "Repository: $REPO_DIR"
    echo "User Data:  $CONTEXT_DNA_DIR"
    echo "OS:         $OS_TYPE"
    echo ""

    if [ "$VERIFY_ONLY" = true ]; then
        print_header "Verifying Installation"
        verify_installation
        exit $?
    fi

    if [ "$HOOKS_ONLY" = true ]; then
        configure_hooks
        print_success "Hooks configuration complete!"
        exit 0
    fi

    # ===========================================
    # Phase 1: Prerequisites
    # ===========================================
    print_header "Phase 1: System Prerequisites"

    if ! check_python; then
        print_error "Python 3.8+ is required. Please install it and re-run this script."
        exit 1
    fi

    if [ "$OS_TYPE" = "Darwin" ]; then
        check_homebrew

        # Setup ARM64 Homebrew + MLX for Apple Silicon (native Metal GPU)
        ARCH=$(uname -m)
        if [ "$ARCH" = "arm64" ]; then
            setup_arm64_homebrew_and_mlx
        fi
    fi

    # ===========================================
    # Phase 2: Adaptive Hierarchy Analysis
    # ===========================================
    print_header "Phase 2: Analyzing Your Codebase Structure"

    run_hierarchy_analysis

    # ===========================================
    # Phase 3: Optional Dependencies
    # ===========================================
    if [ "$QUICK_MODE" = false ]; then
        print_header "Phase 3: Optional Dependencies"

        check_and_install_xbar
        check_and_install_vscode
    else
        print_header "Phase 3: Skipping Optional Dependencies (--quick mode)"
    fi

    # ===========================================
    # Phase 4: Core Installation
    # ===========================================
    print_header "Phase 4: Core Installation"

    create_directories
    setup_venv
    migrate_databases
    configure_hooks
    setup_environment

    # ===========================================
    # Phase 5: Local LLM Backend (uses hierarchy profile)
    # ===========================================
    if [ "$QUICK_MODE" = false ]; then
        install_llm_backend
    else
        print_header "Phase 5: Skipping LLM Backend (--quick mode)"
        print_info "Install later with: python -m context_dna.local_llm.mlx_installer"
    fi

    # ===========================================
    # Phase 6: Verification
    # ===========================================
    print_header "Phase 5: Verification"

    if verify_installation; then
        show_final_instructions
    else
        echo ""
        print_warning "Installation completed with some issues."
        echo "Run '$0 --verify' to check status."
    fi
}

main "$@"
