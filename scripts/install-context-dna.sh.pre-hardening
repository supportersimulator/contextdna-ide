    echo "  ██╔════╝██╔═══██╗████╗  ██║╚══██╔══╝██╔════╝╚██╗██╔╝╚══██╔══╝"
    echo "  ██║     ██║   ██║██╔██╗ ██║   ██║   █████╗   ╚███╔╝    ██║   "
    echo "  ██║     ██║   ██║██║╚██╗██║   ██║   ██╔══╝   ██╔██╗    ██║   "
    echo "  ╚██████╗╚██████╔╝██║ ╚████║   ██║   ███████╗██╔╝ ██╗   ██║   "
    echo "   ╚═════╝ ╚═════╝ ╚═╝  ╚═══╝   ╚═╝   ╚══════╝╚═╝  ╚═╝   ╚═╝   "
    echo "                      ██████╗ ███╗   ██╗ █████╗                 "
    echo "                      ██╔══██╗████╗  ██║██╔══██╗                "
    echo "                      ██║  ██║██╔██╗ ██║███████║                "
    echo "                      ██║  ██║██║╚██╗██║██╔══██║                "
    echo "                      ██████╔╝██║ ╚████║██║  ██║                "
    echo "                      ╚═════╝ ╚═╝  ╚═══╝╚═╝  ╚═╝                "
    echo -e "${NC}"
