#!/bin/bash
# =============================================================================
# Context DNA Installation Wizard
# =============================================================================
# Complete guided setup for the Context DNA learning system
#
# This script handles:
# 1. System prerequisites (Python 3, Homebrew on macOS)
# 2. Optional dependencies (xbar for menu bar, VS Code, Claude Code extension)
# 3. Context DNA package installation
# 4. Claude Code hooks configuration
# 5. Full verification
#
# Usage:
#   ./scripts/install-context-dna.sh           # Full guided installation
#   ./scripts/install-context-dna.sh --quick   # Skip optional dependencies
#   ./scripts/install-context-dna.sh --verify  # Just verify installation
#
# =============================================================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Configuration
CONTEXT_DNA_DIR="${CONTEXT_DNA_DIR:-$HOME/.context-dna}"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_DIR="$REPO_DIR/.venv"
OS_TYPE="$(uname -s)"

# =============================================================================
# Helper Functions
# =============================================================================

