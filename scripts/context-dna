set -e

# Configuration
# CONTEXT_DNA_INFRA_DIR: Docker infrastructure directory (docker-compose, .env, resource profiles)
# Uses symlink context-dna-data -> context-dna/infra for backward compatibility
CONTEXT_DNA_INFRA_DIR="${CONTEXT_DNA_INFRA_DIR:-$HOME/dev/er-simulator-superrepo/context-dna/infra}"
COMPOSE_FILE="$CONTEXT_DNA_INFRA_DIR/docker-compose.yaml"
RESOURCE_PROFILES="$CONTEXT_DNA_INFRA_DIR/resource-profiles.yaml"
ENV_FILE="$CONTEXT_DNA_INFRA_DIR/.env"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

