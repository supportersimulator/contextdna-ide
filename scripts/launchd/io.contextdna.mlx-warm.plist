<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>io.contextdna.mlx-warm</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>__USER_HOME__</string>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
		<key>FLEET_REPO_DIR</key>
		<string>__USER_HOME__/dev/er-simulator-superrepo</string>
	</dict>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__USER_HOME__/dev/er-simulator-superrepo/scripts/warm-mlx-on-boot.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>__USER_HOME__/dev/er-simulator-superrepo/logs/mlx-warm.launchd.log</string>
	<key>StandardOutPath</key>
	<string>__USER_HOME__/dev/er-simulator-superrepo/logs/mlx-warm.launchd.log</string>
	<key>WorkingDirectory</key>
	<string>__USER_HOME__/dev/er-simulator-superrepo</string>
	<key>ThrottleInterval</key>
	<integer>120</integer>
</dict>
</plist>
