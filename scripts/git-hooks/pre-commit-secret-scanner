#!/bin/bash
# Context DNA Secret Scanner - Pre-commit Hook
# Blocks commits containing potential secrets

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔐 Scanning for secrets...${NC}"

# Get staged content
STAGED_DIFF=$(git diff --cached --diff-filter=ACMR)

# Secret patterns to detect
PATTERNS=(
    # API Keys
    'sk-proj-[a-zA-Z0-9]{20,}'           # OpenAI project keys
    'sk-[a-zA-Z0-9]{40,}'                # OpenAI keys
    'ghp_[a-zA-Z0-9]{36}'                # GitHub personal tokens
    'github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}'  # GitHub fine-grained
    'gho_[a-zA-Z0-9]{36}'                # GitHub OAuth
    'AKIA[A-Z0-9]{16}'                   # AWS Access Key ID
    'anthropic-[a-zA-Z0-9-]{30,}'        # Anthropic keys
    'xoxb-[a-zA-Z0-9-]+'                 # Slack bot tokens
    'xoxp-[a-zA-Z0-9-]+'                 # Slack user tokens

    # Private IPs (excluding 0.0.0.0 and 127.0.0.1)
    '10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'      # 10.x.x.x
    '172\.(1[6-9]|2[0-9]|3[0-1])\.[0-9]{1,3}\.[0-9]{1,3}'  # 172.16-31.x.x
    '192\.168\.[0-9]{1,3}\.[0-9]{1,3}'   # 192.168.x.x

    # AWS Resources
    'i-[0-9a-f]{8,17}'                   # EC2 instance IDs
    'ami-[0-9a-f]{8,17}'                 # AMI IDs
    'arn:aws:[a-z0-9-]+:[a-z0-9-]*:[0-9]*:'  # AWS ARNs

    # Generic secrets
    'password\s*[=:]\s*["\047][^"\047]{8,}'   # password = "xxx" or password: 'xxx'
    'secret\s*[=:]\s*["\047][^"\047]{8,}'     # secret = "xxx"
    'api_key\s*[=:]\s*["\047][^"\047]{8,}'    # api_key = "xxx"
    'apikey\s*[=:]\s*["\047][^"\047]{8,}'     # apikey = "xxx"
    'Bearer\s+[a-zA-Z0-9._-]{20,}'       # Bearer tokens
)

# Files to always skip
SKIP_FILES="\.md$|\.txt$|package-lock\.json$|yarn\.lock$|\.git/hooks/"

FOUND_SECRETS=0
DETECTED_ITEMS=""

for pattern in "${PATTERNS[@]}"; do
    # Search staged diff, excluding skip files
    MATCHES=$(echo "$STAGED_DIFF" | grep -v "^-" | grep -E "$pattern" | grep -vE "$SKIP_FILES" | grep -vE "^\+.*#.*example|^\+.*//.*example|^\+.*placeholder" | head -5)

    if [ -n "$MATCHES" ]; then
        FOUND_SECRETS=1
        DETECTED_ITEMS="${DETECTED_ITEMS}\n${YELLOW}Pattern:${NC} $pattern\n${RED}$MATCHES${NC}\n"
    fi
done

# Check for .env files being committed
ENV_FILES=$(git diff --cached --name-only | grep -E "^\.env$|^\.env\.|credentials|secrets\.json|token\.json" | grep -v "\.example$")
if [ -n "$ENV_FILES" ]; then
    FOUND_SECRETS=1
    DETECTED_ITEMS="${DETECTED_ITEMS}\n${YELLOW}⚠️  Sensitive files staged:${NC}\n${RED}$ENV_FILES${NC}\n"
fi

if [ $FOUND_SECRETS -eq 1 ]; then
    echo -e "${RED}⛔ SECRETS DETECTED - COMMIT BLOCKED${NC}"
    echo -e "$DETECTED_ITEMS"
    echo ""
    echo -e "${YELLOW}Options:${NC}"
    echo "  1. Remove secrets and recommit"
    echo "  2. Add to .gitignore if file shouldn't be tracked"
    echo "  3. Use \${PLACEHOLDER} format for examples"
    echo "  4. Override with: git commit --no-verify (use with caution)"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ No secrets detected${NC}"
exit 0
