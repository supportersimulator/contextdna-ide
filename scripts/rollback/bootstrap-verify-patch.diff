 # ============================================================================
+# STEP 3.5 — STORAGE_BACKEND_TOGGLE invariant check
+# ----------------------------------------------------------------------------
+# Compose is up, but containers aren't necessarily "healthy" yet (that's
+# step 4). The storage invariant only needs the local SQLite/Postgres mirror
+# to be reachable — it does NOT depend on the helper agent's /consult
+# endpoint, so we run it here BEFORE step 4 to fail fast if the toggle
+# semantics are broken.
+#
+# Script lives in the OSS repo's migrate4/rollback/ tree; the mothership
+# pins it as a submodule at contextdna-ide-oss/. If the file is missing we
+# log + skip (the mothership may pre-date this submodule pin) — ZSF means
+# the skip is observable, not silent.
+# ============================================================================
+t0=$(date +%s)
+STORAGE_INV_SCRIPT="${TARGET}/contextdna-ide-oss/migrate4/rollback/storage-invariant-check.sh"
+
+if [[ -x "$STORAGE_INV_SCRIPT" ]]; then
+    INV_JSON="${TARGET}/.storage-invariant-last.json"
+    if "$STORAGE_INV_SCRIPT" \
+            --backends "sqlite,auto" \
+            --threshold 0 \
+            --window-ms 100 \
+            --retries 3 \
+            --output-json "$INV_JSON" \
+            --no-rollback >&2; then
+        STEP3_5_STORAGE_INV=1
+        log 3.5 ok "$(( $(date +%s) - t0 ))" \
+            "STORAGE_BACKEND_TOGGLE invariant verified (snapshot=$INV_JSON)"
+    else
+        # Hard-fail: a broken toggle = the Operational Invariance Promise
+        # is itself broken. We let storage-rollback.sh be invoked manually
+        # (--no-rollback above) because bootstrap-verify is supposed to be
+        # observation-only — it never mutates host state.
+        fatal 3.5 "STORAGE_BACKEND_TOGGLE invariant FAILED — see $INV_JSON"
+    fi
+else
+    log 3.5 info 0 "storage-invariant-check.sh not present at $STORAGE_INV_SCRIPT — skipping (counter recorded)"
+fi
+
+# ============================================================================
 # STEP 4 — wait for all containers to become "healthy"
 # ============================================================================
 t0=$(date +%s)
