# Copy this to terraform.tfvars and fill in values

aws_region           = "us-west-2"
environment          = "prod"
project_name         = "ersim"

# Get from AWS Secrets Manager or your credentials
cloudflare_api_token = ""
cloudflare_zone_id   = ""

# SSH public key for the LiveKit instance
ssh_public_key       = ""

# LiveKit credentials (generate new ones or use existing)
livekit_api_key      = ""
livekit_api_secret   = ""
