def get_professor_wisdom(prompt: str, depth: str = "full") -> Optional[str]:
    """Get Professor wisdom (THE ONE THING, LANDMINES, THE PATTERN)."""
    try:
        # Run professor.py
        result = subprocess.run(
            ["python3", str(MEMORY_DIR / "professor.py"), prompt],
            capture_output=True,
            text=True,
            timeout=10
        )

        if result.returncode == 0 and result.stdout.strip():
            output = result.stdout.strip()

            if depth == "one_thing_only":
                # Extract just THE ONE THING
                match = re.search(r"THE ONE THING[:\s]*(.+?)(?:\n|LANDMINES|$)", output, re.DOTALL)
                if match:
                    return f"THE ONE THING: {match.group(1).strip()}"
            elif depth == "summary":
                # First 500 chars
                return output[:500] + "..." if len(output) > 500 else output
            else:
                return output

        return None
    except Exception:
        return None


