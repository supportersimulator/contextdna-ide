RISK_KEYWORDS = {
    RiskLevel.CRITICAL: [
        r"destroy", r"migration.*prod", r"schema.*change", r"auth.*system",
        r"delete.*all", r"drop.*table", r"force.*push.*main"
    ],
    RiskLevel.HIGH: [
        r"deploy", r"terraform", r"migration", r"refactor", r"ecs.*service",
        r"aws", r"production", r"database", r"security", r"ssl", r"cert"
    ],
    RiskLevel.MODERATE: [
        r"docker", r"config", r"env", r"toggle", r"health", r"sync",
        r"update", r"change", r"modify", r"fix", r"bug"
    ],
    RiskLevel.LOW: [
        r"admin", r"dashboard", r"display", r"show", r"add.*button",
        r"style", r"format", r"comment", r"readme"
    ]
}

FIRST_TRY_LIKELIHOOD = {
    RiskLevel.CRITICAL: "5%",
    RiskLevel.HIGH: "30%",
    RiskLevel.MODERATE: "60%",
    RiskLevel.LOW: "90%"
}


def detect_risk_level(prompt: str) -> RiskLevel:
    """Detect risk level from prompt text."""
    prompt_lower = prompt.lower()

    for level in [RiskLevel.CRITICAL, RiskLevel.HIGH, RiskLevel.MODERATE, RiskLevel.LOW]:
        for pattern in RISK_KEYWORDS[level]:
            if re.search(pattern, prompt_lower):
                return level

    return RiskLevel.MODERATE  # Default


