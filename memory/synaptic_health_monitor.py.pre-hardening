            print(f"🟢 {len(running)}/{len(report.services)} services running")
            print()

            for s in report.services:
                if s.running:
                    icon = "✅" if s.healthy else "🟡"
                    print(f"  {icon} {s.name}: {s.message}")
                else:
                    icon = "🔴" if s.importance == "critical" else "⚪"
                    print(f"  {icon} {s.name}: {s.message}")
